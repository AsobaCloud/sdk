{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GapDetectionRequest",
  "description": "Request schema for gapDetectionService to trigger a scan for missing data.",
  "type": "object",
  "required": ["customer_id"],
  "properties": {
    "customer_id": { "type": "string" },
    "client_id": { "type": "string", "default": "asoba" },
    "region": { "type": "string", "default": "af-south-1" },
    "location": { "type": "string", "default": "Durban" },
    "manufacturer": { "type": "string", "default": "Huawei" },
    "lookback_days": { "type": "integer", "default": 7 },
    "min_gap_minutes": { "type": "integer", "default": 15 }
  }
}
