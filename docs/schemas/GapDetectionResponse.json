{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GapDetectionResponse",
  "description": "Response schema for gapDetectionService identifying missing data intervals.",
  "type": "object",
  "required": ["customer_id", "scan_period", "gaps_found", "dates_needing_backfill", "needs_backfill"],
  "properties": {
    "customer_id": { "type": "string" },
    "client_id": { "type": "string" },
    "region": { "type": "string" },
    "location": { "type": "string" },
    "manufacturer": { "type": "string" },
    "scan_period": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" }
      }
    },
    "device_count": { "type": "integer" },
    "devices_scanned": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gaps_found": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "gap_start", "gap_end", "missing_intervals"],
        "properties": {
          "asset_id": { "type": "string" },
          "gap_start": { "type": "string", "format": "date-time" },
          "gap_end": { "type": "string", "format": "date-time" },
          "missing_intervals": { "type": "integer" }
        }
      }
    },
    "dates_needing_backfill": {
      "type": "array",
      "items": { "type": "string", "format": "date" }
    },
    "backfill_targets": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "total_missing_intervals": { "type": "integer" },
    "needs_backfill": { "type": "boolean" }
  }
}
